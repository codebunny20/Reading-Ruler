{
    "manifest_version": 3,
    "name": "Reading Ruler",
    "version": "1.0",
    "description": "A horizontal reading ruler that follows your mouse to improve readability.",
    "permissions": ["activeTab"],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "icons": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "64": "icons/64.png"
    }
  }